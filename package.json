{
  "name": "souverain_bot",
  "version": "1.0.0",
  "description": "Discord Bot - Economy, Dragons, Warfare RPG",
  "main": "dist/main.js",
  "scripts": {
    "dev": "ts-node src/main.ts",
    "dev:watch": "ts-node-dev --respawn src/main.ts",
    "build": "tsc --skipLibCheck --noEmitOnError",
    "start": "node dist/main.js",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate deploy",
    "prisma:studio": "prisma studio",
    "db:push": "prisma db push",
    "db:seed": "ts-node prisma/seed.ts"
  },
  "dependencies": {
    "@prisma/client": "^5.8.0",
    "axios": "^1.14.0",
    "canvas": "^3.2.2",
    "discord.js": "^14.14.0",
    "dotenv": "^16.3.1",
    "node-cron": "^3.0.3",
    "node-html-to-image": "^5.0.0",
    "puppeteer": "^24.40.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.6",
    "@types/node-cron": "^3.0.11",
    "prisma": "^5.8.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
}
